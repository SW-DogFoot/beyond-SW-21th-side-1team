<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.mini.timedeal.domain.promotion.mapper.PromotionMapper">

    <resultMap id="promotionMap" type="com.mini.timedeal.domain.promotion.model.Promotion">
        <id property="id" column="id"/>
        <result property="productId" column="product_id"/>
        <result property="status" column="status"/>
        <result property="discountRate" column="discount_rate"/>
        <result property="totalQuantity" column="total_quantity"/>
        <result property="issuedQuantity" column="issued_quantity"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
    </resultMap>

    <!-- 단건 조회 -->
    <select id="findById" parameterType="long" resultMap="promotionMap">
        SELECT * FROM promotions WHERE id = #{id}
    </select>

    <!-- 전체 조회 -->
    <select id="findAll" resultMap="promotionMap">
        SELECT * FROM promotions
    </select>

    <!-- 상태별 조회 -->
    <select id="findByStatus" parameterType="com.mini.timedeal.enums.PromotionStatus" resultMap="promotionMap">
        SELECT * FROM promotions WHERE status = #{status}
    </select>

    <!-- 등록 -->
    <insert id="insertPromotion" parameterType="com.mini.timedeal.domain.promotion.model.Promotion" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO promotions (product_id, status, discount_rate, total_quantity, issued_quantity, start_time, end_time)
        VALUES (#{productId}, #{status}, #{discountRate}, #{totalQuantity}, #{issuedQuantity}, #{startTime}, #{endTime})
    </insert>

    <!-- 수정 -->
    <update id="updatePromotion" parameterType="com.mini.timedeal.domain.promotion.model.Promotion">
        UPDATE promotions
        SET status = #{status},
            issued_quantity = #{issuedQuantity}
        WHERE id = #{id}
    </update>

    <!-- 삭제 -->
    <delete id="deletePromotion" parameterType="long">
        DELETE FROM promotions WHERE id = #{id}
    </delete>

    <!-- 재고 차감 -->
    <update id="decreaseStock" parameterType="long">
        UPDATE promotions
        SET total_quantity = #{totalQuantity}
        WHERE id = #{id}
    </update>

</mapper>