<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.mini.timedeal.domain.product.mapper.ProductMapper">
    <resultMap id="ProductMap" type="com.mini.timedeal.domain.product.model.Product">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="price" column="price"/>
    </resultMap>

<!--등록, 삭제, 수정, 검색(특정, 전체) -->

    <!--상품 등록-->
    <insert id="insertProduct" parameterType="com.mini.timedeal.domain.product.model.Product" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO products(name, description, price)
        VALUES (#{name}, #{description}, #{price})
    </insert>

    <!-- 상품 삭제 -->
    <delete id="deleteProduct" parameterType="long">
        DELETE FROM products where id = #{id}
    </delete>

    <!-- 상품 수정 -->
    <update id="updateProduct" parameterType="com.mini.timedeal.domain.product.model.Product">
        UPDATE products
        SET name = #{name},
            description = #{description},
            price = #{price}
        WHERE id = #{id}
    </update>

    <!--상품 조회(특정)-->
    <select id="findById" parameterType="long" resultMap="ProductMap">
    SELECT  * FROM products WHERE id = #{id}
    </select>

    <!-- 상품 조회(전체) -->
    <select id="findAll" resultMap="ProductMap">
        SELECT * FROM products
    </select>


</mapper>